---
import * as styles from './sidePanel.css.ts';
import type { ImageMetadata } from 'astro';
import PageLayout from '@layouts/page.astro';

export interface Props {
    title: string;
    layout: string;
    subTitle: string;
    activePage: string;
    image?: ImageMetadata;
    pageBackground?: ImageMetadata;
}

const { title, subTitle, image, activePage, layout = '7fr 3fr', pageBackground } = Astro.props;
---

<style define:vars={{ layout }}></style>

<PageLayout
    title={title}
    subTitle={subTitle}
    image={image}
    activePage={activePage}
    pageBackground={pageBackground}
>
    <div class={styles.sidePanel}>
        <section class={styles.left}>
            <slot />
        </section>
        <aside class={styles.right}>
            <slot name="sidepanel" />
        </aside>
    </div>
</PageLayout>
