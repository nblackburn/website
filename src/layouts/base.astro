---
import '@styles/reset.css';
import { Font } from 'astro:assets';
import * as styles from './base.css.ts';
import Main from '@components/main.vue';
import type { ImageMetadata } from 'astro';
import Header from '@components/header.vue';
import Footer from '@components/footer.vue';
import fallbackImage from '@assets/img/me.jpg';
import DynamicPalette from '@components/dynamicPalette.vue';
import PageBackground from '@components/pageBackground.vue';
import { getActivePalette } from '@utilities/paletteManager';

export interface Props {
    title: string;
    activePage?: string;
    description?: string;
    image?: ImageMetadata;
    pageBackground?: ImageMetadata;
}

const activePalette = getActivePalette();
const { title, description, image, activePage, pageBackground } = Astro.props;
---

<html lang="en">
    <head>
        <!-- title -->
        <title>
            {title ? `Nathaniel Blackburn - ${title}` : 'Nathaniel Blackburn'}
        </title>

        <!-- canonical -->
        <link rel="canonical" href={Astro.url} />

        <!-- meta -->
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width" />
        <meta name="generator" content={Astro.generator} />
        <meta name="description" content={description} />

        <!-- open graph -->
        <meta
            property="og:title"
            content={title
                ? `Nathaniel Blackburn - ${title}`
                : 'Nathaniel Blackburn'}
        />
        <meta property="og:type" content="website" />
        <meta property="og:description" content={description} />
        <meta property="og:url" content={Astro.url} />
        <meta property="og:site_name" content="Nathaniel Blackburn" />
        <meta
            property="og:image"
            content={image ? image.src : fallbackImage.src}
        />

        <!-- twitter -->
        <meta
            property="twitter:title"
            content={title
                ? `Nathaniel Blackburn - ${title}`
                : 'Nathaniel Blackburn'}
        />
        <meta name="twitter:description" content={description} />
        <meta name="twitter:card" content="summary" />
        <meta
            property="twitter:image"
            content={image ? image.src : fallbackImage.src}
        />

        <!-- styles -->
        <Font cssVariable="--font-nunito-sans" preload />

        <!-- icons -->
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

        <!-- feeds ---->
        <link
            rel="alternate"
            type="application/rss+xml"
            title="Nathaniel Blackburn"
            href={new URL('/projects/rss.xml', Astro.site)}
        />
        <link
            rel="alternate"
            type="application/rss+xml"
            title="Nathaniel Blackburn"
            href={new URL('/blog/rss.xml', Astro.site)}
        />
        
        <!-- site maps -->
        <link rel="sitemap" href="/sitemap-index.xml" />

        <!-- scripts -->
        <script
            src="https://gettermscmp.com/cookie-consent/embed/74c62277-9611-4fa1-867a-bacab99408aa/en-au?auto=true"
            is:inline></script>
        
        <script
            src="https://challenges.cloudflare.com/turnstile/v0/api.js"
            is:inline
            async
            defer></script>
    </head>
    <body class:list={[styles.body, activePalette]}>
        <DynamicPalette client:load />
        {pageBackground && <PageBackground image={pageBackground} />}
        
        <Header activePage={activePage} />
        <slot name="hero" />
        <Main>
            <slot />
        </Main>
        <Footer />
    </body>
</html>
